# BECS Production Environment Variables
# Create a copy of this file named '.env' inside the server/ directory on your VPS

# Port for the Express server to listen on (Default: 5000)
PORT=5000

# MongoDB Atlas connection string (ensure to replace username, password, and database name)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/becs_production?retryWrites=true&w=majority

# Secret key used for signing JSON Web Tokens (JWT) (Make this a strong, random key in production!)
JWT_SECRET=your_super_secret_high_entropy_key_here_2026
